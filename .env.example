# --- Site ---
# Used in canonical URLs, OG metadata, and Stripe success/cancel URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (required for real checkout) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Calendly fallback ---
# Optional. Per-service Calendly URLs are hard-coded in src/lib/services.ts;
# this is only used by the generic CalendlyEmbed when no URL is passed.
NEXT_PUBLIC_CALENDLY_URL=

# --- Analytics (optional — site runs without them) ---
# Drop in a GA4 measurement ID to turn on Google Analytics:
NEXT_PUBLIC_GA_ID=
# Drop in a Meta (Facebook) Pixel ID to turn on Meta Pixel tracking:
NEXT_PUBLIC_FB_PIXEL_ID=
